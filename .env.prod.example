# ─── LexiBel Production Environment ─────────────────────────────
# Copy to .env on the server: cp .env.prod.example .env
# Generate secrets: bash scripts/gen-secrets.sh

# ─── OBLIGATOIRES ───────────────────────────────────────────────
POSTGRES_PASSWORD=            # openssl rand -hex 32
SECRET_KEY=                   # openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=         # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=      # python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MINIO_PASSWORD=               # openssl rand -hex 16

# ─── AUTH ADMIN INITIAL ─────────────────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@lexibel.be
BOOTSTRAP_ADMIN_PASSWORD=     # Changer après le premier login!

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=https://lexibel.clixite.cloud

# ─── OAuth Providers (sync email/calendar) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ─── LLM APIs (optionnel) ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
